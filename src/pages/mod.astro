---
import Layout from '../layouts/Layout.astro';
const title = "マイクラmod日本語化ファイル配布ページ";

const files = [
  {name: "FTB Materials",version: "21.1.3",date:"2026/06/20",url:"/homepage/files/JP_FTBmaterials.zip"}
];

---


<Layout title={title}>
  <main class="container">
    <h1>マイクラmod日本語化ファイル配布ページ</h1>
    <p>マインクラフトのmodの日本語化ファイルを配布しております。</p>

    <h2>使用方法</h2>
    <p>resourcepacksフォルダで解凍し、Minecraftを起動し、ワールドを開く。そして、該当のリソースパックを有効化する。</p>
    <table class="download-table">
      <thead>
        <tr>
          <th>mod名</th>
          <th>modバージョン</th>
          <th>更新日</th>
          <th>ダウンロード</th>
        </tr>
      </thead>
      <tbody>
        {files.map((file)=>(
          <tr>
            <td>{file.name}</td>
            <td>{file.version}</td>
            <td>{file.date}</td>
            <td>
              <a href={file.url} download class="download-btn">
                ダウンロード
              </a>
            </td>
          </tr>
        ))}

      </tbody>
    </table>
  </main>
</Layout>

<style>
  .download-table {
    width:100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  .download-table th, .download-table td {
    border-bottom: 1px solid #ddd;
    padding: 6px;
    text-align: left;
  }
  .download-table th {
  background-color: #f4f4f4; 
}
  .download-btn{
    display: inline-block;
    background-color: #9c235e;
    color: white;
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: bold;
  }
  .download-btn:hover{
    background-color: #2c0b1b; 
    transition: background-color 1.0s;
  }
</style>